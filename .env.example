# --- Supabase (hosted at supabase.com; create a project, then copy these values) ---
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE=eyJ...

# Postgres connection string used by `npm run migrate` to apply SQL migrations.
# Copy from: Supabase project → Settings → Database → Connection string (URI),
# and pick the "Session Pooler" entry — it's IPv4 (free) and supports the full
# Postgres protocol that DDL migrations need. Replace [YOUR-PASSWORD] with the
# DB password from the top of the same page.
#
# IMPORTANT: do NOT use the "Direct connection" host (starts with `db.`). On
# Supabase's free tier that endpoint is IPv6-only and most home networks can't
# reach it, giving an instant `EHOSTUNREACH` error. The pooler is IPv4.
#
# Note that with the pooler the username is `postgres.<project-ref>`, NOT just
# `postgres`.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Chat completions, TTS, and example-sentence generation ---
# TODO: Actually use OpenRouter for all these instead of direct OpenAI
OPENROUTER_API_KEY=sk-...
OPENROUTER_CHAT_MODEL=openai/gpt-5.4-mini
OPENROUTER_TTS_MODEL=openai/gpt-4o-mini-tts
OPENROUTER_TTS_VOICE=alloy

# --- Phoneme sidecar ---
# Backend choice: wav2vec2phoneme (CPU, default) or phoneticxeus (GPU only)
PHONEME_BACKEND=wav2vec2phoneme
PHONEME_SERVER_URL=http://phoneme-server:8000

# --- Pronunciation backend selection (sidecar by default) ---
# sidecar: use the local phoneme-server with GOP-SF
# simple-fallback: degraded mode using just argmax + Levenshtein on the sidecar output
PRONUNCIATION_BACKEND=sidecar

# --- Solo-mode auth ---
# A single-user app: set this to a strong random string. The app issues a cookie
# bound to this secret on first visit; subsequent visits are auto-logged-in.
# Rotate to log everyone (you) out.
SOLO_OWNER_SECRET=change-me-to-a-long-random-string
